FROM php:8.2-cli

# Install system dependencies
RUN apt-get update && apt-get install -y \
    git \
    curl \
    libpng-dev \
    libonig-dev \
    libxml2-dev \
    libzip-dev \
    zip \
    unzip \
    libpq-dev \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Install PHP extensions
RUN docker-php-ext-install pdo_pgsql mbstring exif pcntl bcmath gd zip

# Get Composer
COPY --from=composer:latest /usr/bin/composer /usr/bin/composer

# Set working directory
WORKDIR /var/www

# Copy application
COPY . .

# Fix composer lock and install dependencies
RUN rm -f composer.lock && composer install --no-dev --optimize-autoloader --no-interaction

# Set permissions
RUN chown -R www-data:www-data /var/www && chmod -R 755 /var/www

# Create storage directories
RUN mkdir -p storage/framework/{sessions,views,cache} storage/logs \
    && chmod -R 775 storage bootstrap/cache

# Create minimal .env file for Laravel
RUN echo "APP_NAME=DocAvailable" > .env && \
    echo "APP_ENV=production" >> .env && \
    echo "APP_KEY=" >> .env && \
    echo "APP_DEBUG=false" >> .env && \
    echo "APP_URL=https://docavailable-backend.ondigitalocean.app" >> .env && \
    echo "DB_CONNECTION=pgsql" >> .env && \
    echo "DB_HOST=docavailable-db-do-user-25123073-0.h.db.ondigitalocean.com" >> .env && \
    echo "DB_PORT=25060" >> .env && \
    echo "DB_DATABASE=defaultdb" >> .env && \
    echo "DB_USERNAME=doadmin" >> .env && \
    echo "DB_PASSWORD=" >> .env && \
    echo "DB_SSLMODE=require" >> .env

# Start the application - generate key, try migrations, then start server
CMD ["sh", "-c", "export DB_CONNECTION=pgsql && export DB_PORT=25060 && php artisan key:generate --force && php artisan migrate --force || echo 'Migrations failed, continuing...' && php -S 0.0.0.0:8080 -t public"]
